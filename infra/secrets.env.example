# infra/secrets.env.example
#
# Template for the fallback secrets file at ~/.config/agenticos/infra.env.
# Use this ONLY if you can't use the 1Password CLI path (recommended).
#
# Setup:
#   mkdir -p ~/.config/agenticos
#   cp infra/secrets.env.example ~/.config/agenticos/infra.env
#   chmod 600 ~/.config/agenticos/infra.env
#   # then edit ~/.config/agenticos/infra.env with real values
#
# The loader (infra/scripts/load-secrets.sh) refuses to load this file
# unless permissions are 0600 or 0400.

# DigitalOcean: DO Console → API → Tokens → Personal access tokens → Generate
TF_VAR_do_token="dop_v1_REPLACE_ME"

# Tailscale: https://login.tailscale.com/admin/settings/keys → Generate API key
TF_VAR_tailscale_api_key="tskey-api-REPLACE_ME"

# Tailscale tailnet name (email-shaped string at top of Tailscale admin)
TF_VAR_tailscale_tailnet="josh@goldberrygrove.farm"

# Cloudflare API token (Profile → API Tokens → Custom token with DNS+Access+Tunnel edit)
TF_VAR_cloudflare_api_token="REPLACE_ME"

# Cloudflare zone ID (Cloudflare → gatheringatthegrove.com zone → Overview sidebar)
TF_VAR_cloudflare_zone_id="REPLACE_ME"

# Cloudflare account ID (same page, sidebar)
TF_VAR_cloudflare_account_id="REPLACE_ME"
