# infra/secrets.env.example
#
# Template for the fallback secrets file at ~/.config/agenticos/infra.env.
# Use this ONLY if you can't use the 1Password CLI path (recommended).
#
# Setup:
#   mkdir -p ~/.config/agenticos
#   cp infra/secrets.env.example ~/.config/agenticos/infra.env
#   chmod 600 ~/.config/agenticos/infra.env
#   # then edit ~/.config/agenticos/infra.env with real values
#
# The loader (infra/scripts/load-secrets.sh) refuses to load this file
# unless permissions are 0600 or 0400.

# DigitalOcean: DO Console → API → Tokens → Personal access tokens → Generate
TF_VAR_do_token="dop_v1_REPLACE_ME"

# Tailscale: https://login.tailscale.com/admin/settings/keys → Generate API key
TF_VAR_tailscale_api_key="tskey-api-REPLACE_ME"

# Tailscale tailnet identifier. Two valid forms:
#   1. Your tailnet name (recommended) — domain-style or email-shaped, found
#      under "Tailnet name" at https://login.tailscale.com/admin/general
#      (e.g. "goldberrygrove.farm"). NOT the "Tailnet ID" — that's a different
#      value the REST API doesn't accept in URL paths.
#   2. The literal "-" — wildcard meaning "the tailnet of this API key".
TF_VAR_tailscale_tailnet="goldberrygrove.farm"

# Cloudflare API token (Profile → API Tokens → Custom token with DNS+Access+Tunnel edit)
TF_VAR_cloudflare_api_token="REPLACE_ME"

# Cloudflare zone ID (Cloudflare → gatheringatthegrove.com zone → Overview sidebar)
TF_VAR_cloudflare_zone_id="REPLACE_ME"

# Cloudflare account ID (same page, sidebar)
TF_VAR_cloudflare_account_id="REPLACE_ME"

# Paperclip integration (dashboard data-source repoint)
# paperclip_company_id: UUID of the GOL company row — get via:
#   psql $PAPERCLIP_DB_URL -c "SELECT id FROM companies WHERE name ILIKE '%goldberry%';"
TF_VAR_paperclip_company_id="REPLACE_ME"
# paperclip_board_key: Board API key from Paperclip admin or 1Password
TF_VAR_paperclip_board_key="REPLACE_ME"

# --- Observability: AgenticOS OTel Collector → obs-droplet OpenObserve (GOL-54) --------------
# These live in /opt/agenticos/.env on the Droplet (NOT TF_VAR_*; consumed by the otel-collector
# container via env_file). The collector only starts when OPENOBSERVE_OTLP_BASE is set (it is
# behind the `observability` compose profile). Prefer 1Password/secret injection over plaintext.
# obs-droplet OpenObserve OTLP-HTTP base, e.g. https://obs.gatheringatthegrove.com/api/default
OPENOBSERVE_OTLP_BASE="REPLACE_ME"
# OpenObserve ingest creds. TODAY: obs-droplet root basicauth. FOLLOW-UP: scoped ingest-only user.
OPENOBSERVE_ROOT_EMAIL="REPLACE_ME"
OPENOBSERVE_ROOT_PASSWORD="REPLACE_ME"
