{
  "name": "@agenticos/vault-server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist/server.cjs",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --target=node22 --alias:server-only=./shims/server-only.js --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@agenticos/vault-core": "workspace:*",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
