# infra/terraform/.envrc
#
# direnv config — automatically loads AgenticOS infra secrets as TF_VAR_*
# environment variables when you `cd infra/terraform`.
#
# Setup (one-time):
#   1. Install direnv:  brew install direnv
#   2. Add hook to shell rc:
#        eval "$(direnv hook bash)"   # ~/.bashrc
#        eval "$(direnv hook zsh)"    # ~/.zshrc
#   3. cd into this directory and run:  direnv allow
#
# Without direnv (manual): just source the script directly:
#   source ../scripts/load-secrets.sh

# Resolve the loader path relative to this file (works regardless of cwd)
_loader="$(cd "$(dirname "${BASH_SOURCE[0]:-${(%):-%x}}")/.." && pwd)/scripts/load-secrets.sh"

if [ -f "$_loader" ]; then
    # shellcheck disable=SC1090
    source "$_loader"
else
    echo "ERROR: load-secrets.sh not found at expected path: $_loader" >&2
fi

unset _loader
