# Copy to terraform.tfvars and fill ONLY if you need to override defaults.
# terraform.tfvars is git-ignored.
#
# Provider credentials (do_token, github_token, spaces_bootstrap_*) should NEVER
# live in a tfvars file — fetch them from 1Password at apply time:
#
#   op run --env-file=.env.op -- terraform apply
#
# That injects them as TF_VAR_* without ever materializing the values in shell
# scrollback, history, or this file.

# Optional overrides (defaults are usually right):
# region              = "nyc3"
# bucket_name         = "agenticos-tfstate"
# github_secrets_repo = "EngineeringMoonBear/AgenticOS"
