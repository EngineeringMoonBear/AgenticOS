# Mounted to /paperclip/.gitconfig (= $HOME/.gitconfig for the `node` user that
# runs agents). Routes all github.com auth through the GitHub App credential
# helper so `git` clone/fetch/push work across every installed org with no
# long-lived token. See scripts/agent-git/github-app-token.mjs and
# docs/agent-house-rules.md.
[user]
	name = AgenticOS Developer
	email = agenticos-developer[bot]@users.noreply.github.com
[credential "https://github.com"]
	# `!node …` runs the script as a shell command; git appends the operation
	# (get/store/erase). useHttpPath gives the helper `path=owner/repo` so it can
	# pick the right installation per owner.
	helper = "!node /paperclip/agent-git/github-app-token.mjs"
	useHttpPath = true
[init]
	defaultBranch = main
[safe]
	# Agents work in node-owned worktrees under PAPERCLIP_HOME — same uid, so
	# git's dubious-ownership check never fires for their own clones regardless of
	# this setting. Scope trust to that root instead of a blanket '*', so a repo
	# owned by a DIFFERENT uid (not one of the agent's own clones) is NOT
	# auto-trusted.
	directory = /paperclip
[core]
	# Agents operate on untrusted external repos — never run repo-provided git
	# hooks. A hostile repo could ship a post-checkout / pre-commit / fsmonitor
	# hook that executes during a routine `git` call with the agent's write token
	# attached. Agent workflows don't depend on repo hooks.
	hooksPath = /dev/null
