node_modules/
.pnpm-store/
# Sandcastle spike: per-repo sandbox scaffold/scratch (Dockerfile, .env, logs,
# worktrees) created by `sandcastle init` at the repo root. Spike-local; never
# commit (the .env there holds the OpenAI key).
.sandcastle/
.next/
.turbo/
dist/
# EXCEPTION: the Paperclip plugins' built dist/ IS committed. The Droplet
# deploy ships the tree via `git archive` (committed files only) and bind-mounts
# the plugins as prebuilt artifacts (they are NOT built on the Droplet), so the
# manifest + worker bundles must be in git or Paperclip can't activate them
# ("no longer exposes a Paperclip manifest"). Rebuild after editing plugin src:
#   pnpm --filter @agenticos/<name>-plugin run build
!packages/vault-plugin/dist/
!packages/openviking-plugin/dist/
!packages/github-plugin/dist/
!packages/github-sync-plugin/dist/
build/
out/
.env
.env.local
.env.*.local
!.env.example
.DS_Store
# macOS Finder/iCloud Drive copy-on-conflict artifacts.
# Pattern: any path like "watcher 2.py" or "Dockerfile 3" — Finder/iCloud
# appends " N" (with leading space) before any extension when it detects a
# sibling already at the same path. Purely a sync-collision artifact, never
# source. Globs cover both with-extension (* 2.*) and bare (* 2) cases.
* [234].*
* [234]
.vscode/
.idea/
*.swp
*.log
coverage/
.nyc_output/
*.tsbuildinfo

# Claude Code local state
.claude/

# Terraform
infra/terraform/terraform.tfvars
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/crash.log
infra/terraform/crash.*.log

# Vendored dependencies
vendor/

